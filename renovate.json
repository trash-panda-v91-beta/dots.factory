{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>trash-panda-v91-beta/renovate-config"
  ],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["after 2am and before 3am on monday"]
  },
  "packageRules": [
    {
      "description": "Group all mise tool updates into a single PR",
      "groupName": "mise tools",
      "matchManagers": ["mise"],
      "schedule": ["every weekend"]
    }
  ]
}
