#!/usr/bin/env bash
#MISE description="Build and activate darwin configuration for the current host"

set -euo pipefail

host="${HOST_ALIAS:-$(hostname -s)}"

echo "Building configuration for '$host' ..."
if [ "$host" = "cmb" ]; then
	result=$(NPINS_OVERRIDE_corpo="../dots.corpo" \
		nix-build default.nix -A "darwinConfigurations.$host.system" \
		--no-out-link --impure)
else
	result=$(nix-build default.nix -A "darwinConfigurations.$host.system" --no-out-link)
fi

echo "Activating ..."
sudo "$result/sw/bin/darwin-rebuild" activate
